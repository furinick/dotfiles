{
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 10,
  "control-center-margin-bottom": 10,
  "control-center-margin-right": 10,
  "control-center-width": 500,
  "control-center-height": 1000,
  "notification-window-width": 500,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "widgets": [
    "title",
    "buttons-grid#quick",
    "notifications",
    "volume",
    "backlight",
    "buttons-grid#power"
  ],
  "widget-config": {
    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "buttons-grid#quick": {
      "actions": [
        {
          "label": "󰖩",
          "command": "nmtui"
        },
        {
          "label": "󰂯",
          "command": "blueman-manager"
        },
        {
          "label": "⟲",
          "command": "swaync-client --reload-config"
        }
      ]
    },
    "buttons-grid#power": {
      "actions": [
        {
          "label": "󰐥",
          "command": "hyprshutdown -t 'Shutting down...' --post-cmd 'shutdown -P 0'"
        },
        {
          "label": "󰜉",
          "command": "hyprshutdown -t 'Rebooting...' --post-cmd 'shutdown -r 0'"
        },
        {
          "label": "󰌾",
          "command": "hyprlock"
        },
        {
          "label": "󰍃",
          "command": "hyprctl dispatch exit"
        }
      ]
    },
    "volume": {
      "label": "󰕾"
    },
    "backlight": {
      "label": "󰃠"
    }
  }
}
